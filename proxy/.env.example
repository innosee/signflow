PORT=3000
ALLOWED_ORIGIN=https://signflow.coach

# HMAC Shared Secret — identisch mit IONOS_PROXY_SHARED_SECRET in Vercel-Env
# Sicher generieren: openssl rand -base64 48
IONOS_PROXY_SHARED_SECRET=

# IONOS AI Model Hub (nur für Stage 3 / Residual-Pass)
# Token im IONOS-Cloud-Portal → „AI Model Hub" → API-Token generieren
IONOS_AI_TOKEN=
IONOS_AI_ENDPOINT=https://openai.inference.de-txl.ionos.com/v1/chat/completions
IONOS_AI_MODEL=meta-llama/Llama-3.3-70B-Instruct

# GLiNER-Sidecar (Stage 2)
PYTHON_BIN=/home/signflow/app/python/.venv/bin/python
GLINER_SCRIPT=python/gliner_server.py
GLINER_MODEL=knowledgator/gliner-pii-base-v1.0
GLINER_THRESHOLD=0.5

# Stage-Kill-Switches für Debugging (leer = aktiv)
# STAGE2_GLINER=off
# STAGE3_LLAMA=off
