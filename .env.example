# === Better Auth ===
BETTER_AUTH_SECRET="<generate: openssl rand -base64 32>"
BETTER_AUTH_URL="https://signflow.coach"
NEXT_PUBLIC_BETTER_AUTH_URL="https://signflow.coach"
NEXT_PUBLIC_APP_URL="https://signflow.coach"

# === Datenbank (Neon, Region eu-central-1) ===
DATABASE_URL="postgresql://USER:PASSWORD@HOST.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# === Storage (Vercel Blob) ===
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# === E-Mail (Resend) ===
# API-Key aus resend.com → API Keys
RESEND_API_KEY="re_..."
# Verifizierte Absender-Adresse. Domain muss bei Resend verifiziert sein
# (DKIM + SPF + DMARC im Vercel-DNS). Format: "Anzeigename <adresse@domain>"
EMAIL_FROM="Signflow <hello@signflow.coach>"
# Empfänger-Inbox für Waitlist-Einträge von der Landing-Page
WAITLIST_INBOX="info@innosee.de"

# === Cloudflare Turnstile (Bot-Schutz für Waitlist) ===
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# === Firma.dev (FES) ===
# Default = mock. Auf "live" stellen, sobald Firma.dev-Account + API-Key da sind.
FIRMA_DEV_MODE="mock"
FIRMA_DEV_API_KEY=""

# === Abschlussbericht-Checker (IONOS-Proxy + Azure OpenAI) ===
# IONOS_PROXY_URL: URL des Anon-Proxy (separates Repo signflow-anon-proxy,
#                   deployed auf IONOS Compute Engine VM in Frankfurt).
# IONOS_PROXY_SHARED_SECRET: muss exakt mit PROXY_SHARED_SECRET im Proxy-.env
#                            übereinstimmen (HMAC-Signing des Browser-Tokens).
#                            Wenn beide leer: Checker bypasst Anonymisierung
#                            und sendet Klartext an Azure (nur Dev/Test!).
# Siehe docs/abschlussbericht-checker.md §2 für Architektur.
IONOS_PROXY_URL="https://anon.signflow.coach"
IONOS_PROXY_SHARED_SECRET=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT=""

# === Puppeteer (PDF-Render) ===
# Nur lokal setzen, wenn System-Chrome genutzt werden soll.
# In Production (Vercel) wird @sparticuz/chromium benutzt.
# PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
